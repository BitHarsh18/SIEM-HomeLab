<group name="local,syslog,sshd,">

  <rule id="100500" level="12">
    <if_group>sysmon_event1</if_group>

    <field name="win.eventdata.commandLine" type="pcre2">
      (?i)powershell.*ExecutionPolicy\s+Bypass
    </field>

    <description>
      Custom Detection: PowerShell ExecutionPolicy Bypass detected
    </description>

    <mitre>
      <id>T1059.001</id>
    </mitre>

    <group>
      custom_detection,
      powershell,
      execution
    </group>

  </rule>

</group>
